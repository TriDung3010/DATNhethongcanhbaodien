' PHẦN 5: Chi tiết format JSON giao tiếp
' ═════════════════════════════════════════════════════

@startuml
!theme plain
skinparam backgroundColor #FEFEFE
title GIAO TIẾP GIỮA CÁC THÀNH PHẦN

rectangle "ESP32" as esp
rectangle "REST API\n/api/v1/sensor-data" as api
rectangle "WebSocket\nSTOMP /topic/alert" as ws
rectangle "Dashboard" as dash

note right of esp
  === POST JSON ===
  {
    "deviceId": "ESP32_NHA_MO_HINH",
    "leakageCurrent": 45.2,
    "unit": "mA",
    "alert": true,
    "relayState": false,
    "timestamp": "1234567"
  }
  
  HEADERS:
  Content-Type: application/json
end note

note left of api
  === RESPONSE 201 ===
  {
    "id": 157,
    "deviceId": "ESP32_NHA_MO_HINH",
    "leakageCurrent": 45.2,
    "alert": true,
    "relayState": false,
    "timestamp": "2026-06-19T14:30:00"
  }
end note

note left of ws
  === STOMP Frame ===
  Topic: /topic/alert
  
  {
    "deviceId": "ESP32_NHA_MO_HINH",
    "leakageCurrent": 45.2,
    "alertType": "LEAKAGE_DETECTED",
    "description": "Phát hiện rò rỉ 45.2mA - Đã ngắt tải"
  }
end note

note right of dash
  === REST GET ===
  GET /api/v1/sensor-data/latest
  GET /api/v1/alerts
end note

esp -down-> api : HTTP POST (3s)
api -down-> ws : Push when alert
ws -down-> dash : STOMP subscribe
dash -up-> api : HTTP GET (khi tải trang)
@enduml



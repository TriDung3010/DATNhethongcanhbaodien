@startuml
!theme plain
skinparam backgroundColor #FEFEFE
title SƠ ĐỒ ĐẤU DÂY ESP32 - BREADBOARD

component "ESP32 DevKit V1" as esp {
  portin "GPIO 32" as p32
  portin "GPIO 14" as p14
  portin "GPIO 12" as p12
  portin "GPIO 25" as p25
  portin "GPIO 33" as p33
  portin "GPIO 13" as p13
  portin "GPIO 19" as p19
  portin "GPIO 34 (ADC)" as p34
  portin "GPIO 35 (ADC)" as p35
  portin "GPIO 26" as p26
  portin "GPIO 27" as p27
  portin "5V" as p5v
  portin "3.3V" as p33v
  portin "GND" as pgnd
}

package "Thiết bị ngõ ra" as outputs {
  component "LED TRẮNG #1\n(Phòng khách)" as led1
  component "LED TRẮNG #2\n(Bếp)" as led2
  component "LED TRẮNG #3\n(Quạt)" as led3
  component "LED XANH\n(Bình thường)" as ledx
  component "LED ĐỎ\n(Rò rỉ)" as ledd
  component "RELAY\n(Ngắt tải)" as relay
  component "BUZZER\n(Còi báo)" as buzz
}

package "Thiết bị ngõ vào" as inputs {
  component "ZCT SCT013\n(Cảm biến dòng)" as zct
  component "BIẾN TRỞ 10kΩ\n(Chỉnh mức rò)" as pot
  component "NÚT NHẤN RÒ RỈ\n(Pull-down 10k)" as btn1
  component "NÚT NHẤN RESET\n(Pull-down 10k)" as btn2
}

package "Nguồn" as psu {
  component "ADAPTER 12V\nDC 1A" as adp
  component "DC-DC LM2596\n12V → 5V" as dcdc
}

' Kết nối đèn
p32 -[#red]-down-> led1 : +220Ω
p14 -[#red]-down-> led2 : +220Ω
p12 -[#red]-down-> led3 : +220Ω
p25 -[#green]-down-> ledx : +220Ω
p33 -[#red]-left-> ledd : +220Ω

' Kết nối ngõ ra
p26 -down-> relay
p27 -down-> buzz

' Kết nối ngõ vào
p34 -down-> zct
p35 -down-> pot
p13 -down-> btn1
p19 -down-> btn2

' Nguồn
adp -right-> dcdc : 12V
dcdc -right-> p5v : 5V
dcdc --> pgnd

p33v -down-> pot : VCC
p33v -down-> zct : (nếu cần)

@enduml

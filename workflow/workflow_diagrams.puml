' ═════════════════════════════════════════════════════
' PHẦN 2: Activity Diagram - Active Edge Alert
' ═════════════════════════════════════════════════════

@startuml
!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Arial
title QUY TRÌNH XỬ LÝ CẢNH BÁO (Edge Alert - Active Low)

start
:Khởi tạo ESP32;
:pinMode các chân OUTPUT/INPUT;
:connectWiFi();
:controlApplianceLEDs(true);
:Bật LED thiết bị lúc đầu;

repeat
  :readButtons();
  
  if (Nút RÒ RỈ được nhấn?) then (Có)
    :simulateLeak = !simulateLeak;
    :Serial print "RO RI: BAT/TAT";
  endif
  
  if (Nút RESET được nhấn?) then (Có)
    :simulateLeak = false;
    :alertActive = false;
    :digitalWrite(PIN_RELAY, LOW);
    :controlApplianceLEDs(true);
  endif
  
  ' ── Đọc dòng rò ──
  if (simulateLeak == true?) then (Có - Giả lập)
    :potValue = analogRead(PIN_POT);
    :leakageCurrent = potValue * 100 / 4095;
    note right: 0..4095 → 0..100 mA
  else (Không - ZCT thật)
    :rawMin=4095, rawMax=0;
    repeat (50 lần)
      :raw = analogRead(PIN_ZCT);
      :Cập nhật rawMin/rawMax;
      :delayMicroseconds(100);
    repeatwhile
    :peakToPeak = rawMax - rawMin;
    :voltageRms = (p2p/2)*(3.3/4095)*0.707;
    :currentMA = (voltageRms/0.1)*1000;
    :if (currentMA < 2.0) currentMA = 0.0;
  endif
  
  ' ── Edge Alert ──
  if (leakageCurrent >= 30mA?) then (Có - Rò rỉ)
    if (alertActive == false?) then (Vừa vượt ngưỡng → TRUE edge)
      :alertActive = true;
      :relayOn = false;
      :digitalWrite(PIN_RELAY, HIGH);
      :controlApplianceLEDs(false);
      :println "!!! CANH BAO: Da ngat dien!";
      :Gửi alert=true lên Server;
    endif
    :controlBuzzer(): Nhấp nháy 300ms;
    :digitalWrite(PIN_LED, blink 200ms);
  else (Không - Bình thường)
    if (alertActive == true?) then (Vừa hết rò → FALSE edge)
      :alertActive = false;
      :relayOn = true;
      :digitalWrite(PIN_RELAY, LOW);
      :controlApplianceLEDs(true);
      :println "Het canh bao. Dong dien tro lai.";
      :Gửi alert=false lên Server;
    endif
    :digitalWrite(PIN_BUZZER, LOW);
  endif
  
  :printStatus() Serial;
  
  ' ── Gửi định kỳ ──
  if (millis() - lastSendTime >= 3000ms?) then (Có)
    :Tạo JSON payload;
    :HTTP POST đến SERVER_URL;
    if (HTTP thành công?) then (Có)
      :println "Server: " + response;
    else (Không)
      :print ".";
    endif
    :lastSendTime = millis();
  endif
  
  :delay(200);
  
repeat while (Luôn chạy)

@enduml


' ═════════════════════════════════════════════════════
' PHẦN 3: Quy trình Backend xử lý request
' ═════════════════════════════════════════════════════

@startuml
!theme plain
skinparam backgroundColor #FEFEFE
title QUY TRÌNH BACKEND XỬ LÝ DỮ LIỆU

actor "ESP32" as esp
participant "SensorDataController" as ctrl
participant "SensorDataService" as svc
participant "SensorDataRepository" as repo
participant "AlertHistoryRepository" as alertRepo
database "MySQL" as db
participant "WebSocket" as ws
actor "Dashboard" as dash

== 1. ESP32 gửi dữ liệu ==
esp -> ctrl: POST /api/v1/sensor-data\nContent-Type: application/json\n{deviceId, leakageCurrent, alert, relayState}

ctrl -> ctrl: @Valid kiểm tra DTO
ctrl -> svc: processSensorData(dto)

svc -> svc: SensorData entity\n→ setTimestamp(LocalDateTime.now())

svc -> repo: save(sensorData)
repo -> db: INSERT INTO sensor_data...
db --> repo: OK

svc -> svc: Kiểm tra dto.getAlert()

alt alert == true
    svc -> svc: Tạo AlertHistory entity\n→ setAlertType("LEAKAGE_DETECTED")\n→ setDescription("Dòng rò: XmA")
    svc -> alertRepo: save(alertHistory)
    alertRepo -> db: INSERT INTO alert_history...
    
    svc -> svc: Tạo AlertEventDTO
    svc -> ws: convertAndSend("/topic/alert", alertEventDTO)
    ws -> ws: Gửi STOMP frame đến subscribers
    ws -> dash: Nhận alert event
    note right: Dashboard:\nPopup + Âm thanh + Chart
    
else alert == false
    svc -> svc: Nếu có alert chưa resolved, cập nhật
    svc -> alertRepo: findByDeviceIdAndResolvedFalse
    svc -> alertRepo: setResolved(true), setTimestamp(now)
    svc -> ws: convertAndSend("/topic/alert", {alert=false})
    ws -> dash: Trạng thái bình thường
end

ctrl --> esp: 201 Created + SensorDataDTO

== 2. Dashboard tải dữ liệu lịch sử ==
dash -> ctrl: GET /api/v1/sensor-data/latest
ctrl -> svc: getLatestData()
svc -> repo: findTopByOrderByTimestampDesc()
repo --> svc: SensorData
svc --> ctrl: SensorDataDTO
ctrl --> dash: 200 OK + {latest data}

dash -> ctrl: GET /api/v1/alerts
ctrl -> svc: getAlerts()
svc -> alertRepo: findFirst20ByOrderByTimestampDesc()
alertRepo --> svc: List<AlertHistory>
svc --> ctrl: List<AlertEventDTO>
ctrl --> dash: 200 OK + [alerts...]

@enduml


